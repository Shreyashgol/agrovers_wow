# Vercel ignore file - exclude these from deployment

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/

# Local env files (use Vercel dashboard for env vars)
.env
.env.local
.env.*.local

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# Documentation (not needed in deployment)
README.md
*.md

# Scripts (not needed in deployment)
*.sh
