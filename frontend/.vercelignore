# Vercel ignore file - exclude these from deployment

# Dependencies
node_modules/

# Build output (will be rebuilt)
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Testing
coverage/
.nyc_output/

# Local env files (use Vercel dashboard for env vars)
.env.local
.env.*.local

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/
temp/
*.tmp

# Documentation (not needed in deployment)
README.md
VOICE_FEATURES_README.md
